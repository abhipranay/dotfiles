#!/bin/bash
set -e

{{ if eq .chezmoi.os "darwin" -}}
echo "Installing packages via Homebrew..."

if ! command -v brew &> /dev/null; then
/bin/bash -c "$(curl -fsSL
https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
fi

brew tap aviator-co/tap 2>/dev/null || true
brew tap go-task/tap 2>/dev/null || true

brew install \
aviator-co/tap/av bash-completion chezmoi colordiff coreutils curl \
docker docker-buildx docker-compose fd fzf gh git-delta gnu-sed go \
go-task/tap/go-task grpcurl helm jq k9s lazygit libmagic libpq \
luarocks mkcert neovim openjdk@11 pipx ripgrep tmux wget yarn yq

pipx install ipython
gh extension install dlvhdr/gh-dash 2>/dev/null || true

{{ else if eq .chezmoi.os "linux" -}}
echo "Installing packages via DNF..."

# Enable COPR repos (ignore failures)
sudo dnf copr enable -y atim/lazygit 2>/dev/null || true

# Install available packages (skip unavailable with --skip-unavailable)
sudo dnf install -y --skip-unavailable \
  bash-completion colordiff coreutils curl fd-find file-libs fzf gh \
  git-delta golang helm java-11-openjdk jq lazygit libpq-devel \
  luarocks neovim pipx postgresql-libs ripgrep tmux wget yarnpkg yq \
  2>/dev/null || echo "Some packages may not be available, continuing..."

# Install starship prompt to user directory
if ! command -v starship &> /dev/null; then
  echo "Installing starship to ~/.local/bin..."
  mkdir -p ~/.local/bin
  curl -sS https://starship.rs/install.sh | sh -s -- -y -b ~/.local/bin
fi

# Install Docker only if not in container and not already installed
if [ ! -f /.dockerenv ] && ! command -v docker &> /dev/null; then
  sudo dnf -y install dnf-plugins-core 2>/dev/null || true
  sudo dnf config-manager --add-repo https://download.docker.com/linux/fedora/docker-ce.repo 2>/dev/null || true
  sudo dnf install -y docker-ce docker-ce-cli containerd.io docker-buildx-plugin docker-compose-plugin 2>/dev/null || true
  sudo systemctl enable --now docker 2>/dev/null || true
  sudo usermod -aG docker $USER 2>/dev/null || true
fi

# Install tools via go/curl if not present
command -v chezmoi &> /dev/null || sh -c "$(curl -fsLS get.chezmoi.io)"
command -v grpcurl &> /dev/null || go install github.com/fullstorydev/grpcurl/cmd/grpcurl@latest 2>/dev/null || true
command -v task &> /dev/null || go install github.com/go-task/task/v3/cmd/task@latest 2>/dev/null || true
command -v av &> /dev/null || curl -sSL https://raw.githubusercontent.com/aviator-co/av/main/install.sh | bash 2>/dev/null || true

# Python tools
pipx ensurepath 2>/dev/null || true
pipx install ipython 2>/dev/null || true

# GitHub CLI extensions
gh extension install dlvhdr/gh-dash 2>/dev/null || true

{{ end -}}

echo "Package installation complete!"
